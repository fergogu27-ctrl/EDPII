          ]
        }
      ],
      "source": [
        "# Esta cantidad resume el promedio de todas las medias bootstrap\n",
        "media_de_medias_bootstrap = np.mean(medias_bootstrap)\n",
        "\n",
        "print('Media de las medias bootstrap:')\n",
        "print(media_de_medias_bootstrap)"
      ]
    },
    {
      "cell_type": "markdown",
      "id": "aff67978",
      "metadata": {
        "id": "aff67978"
      },
      "source": [
        "## 6. Desviación estándar Bootstrap\n",
        "\n",
        "La desviación estándar de las medias Bootstrap se interpreta como una estimación del error estándar de la media."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 43,
      "id": "a68b1343",
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "a68b1343",
        "outputId": "cca30a45-957f-4e8e-b945-2d1a0e0e0043"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Desviación estándar bootstrap:\n",
            "0.8885726414406954\n"
          ]
        }
      ],
      "source": [
        "\n",
        "desviacion_estandar_bootstrap = np.std(medias_bootstrap, ddof=1)\n",
        "\n",
        "print('Desviación estándar bootstrap:')\n",
        "print(desviacion_estandar_bootstrap)"
      ]
    },
    {
      "cell_type": "markdown",
      "id": "39dbd01e",
      "metadata": {
        "id": "39dbd01e"
      },
      "source": [
        "## 7. Percentiles 2.5% y 97.5%\n",
        "\n",
        "Para construir un intervalo de confianza Bootstrap al 95%, usamos los percentiles 2.5% y 97.5%."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 44,
      "id": "55934b84",
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "55934b84",
        "outputId": "cfe55cfe-b67b-4cf4-9ca5-dab82518f885"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Percentil 2.5%:\n",
            "38.333333333333336\n",
            "\n",
            "Percentil 97.5%:\n",
            "41.75\n"
          ]
        }
      ],
      "source": [
        "# Para construir un intervalo de confianza bootstrap al 95%,\n",
        "# usamos los percentiles 2.5% y 97.5%\n",
        "percentil_025 = np.percentile(medias_bootstrap, 2.5)\n",
        "percentil_975 = np.percentile(medias_bootstrap, 97.5)\n",
        "\n",
        "print('Percentil 2.5%:')\n",
        "print(percentil_025)\n",
        "\n",
        "print('\\nPercentil 97.5%:')\n",
        "print(percentil_975)"
      ]
    },
    {
      "cell_type": "markdown",
      "id": "302dc902",
      "metadata": {
        "id": "302dc902"
      },
      "source": [
        "## 8. Intervalo de confianza Bootstrap al 95%\n",
        "\n",
        "El intervalo queda dado por:\n",
        "$$[P_{2.5}, P_{97.5}]$$\n",
        "\n",
        "donde $P_{2.5}$ y $P_{97.5}$ son los percentiles 2.5% y 97.5% de las medias Bootstrap."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 45,
      "id": "6ffd967e",
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "6ffd967e",
        "outputId": "a294d3f2-b27d-4c85-fbf8-74e1e04342ba"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Intervalo de confianza Bootstrap al 95%:\n",
            "(np.float64(38.333333333333336), np.float64(41.75))\n"
          ]
        }
      ],
      "source": [
        "# El intervalo bootstrap al 95% queda formado por:\n",
        "# [percentil 2.5%, percentil 97.5%]\n",
        "intervalo_confianza = (percentil_025, percentil_975)\n",
        "\n",
        "print('Intervalo de confianza Bootstrap al 95%:')\n",
        "print(intervalo_confianza)"
      ]
    },
